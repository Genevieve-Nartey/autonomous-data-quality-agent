-11  2023-04-10       156.15          22  South  \n","2  2022-03-05  2024-07-17       280.67          29   West  \n","3  2021-09-02  2023-07-17       177.42          46  South  \n","4  2023-06-14  2023-09-27       111.70          13  North  "]},"execution_count":5,"metadata":{},"output_type":"execute_result"}],"source":["def generate_dirty_dataset(path: Path, n_rows: int = 1000, seed: int = 42) -> pd.DataFrame:\n","    random.seed(seed)\n","    np.random.seed(seed)\n","\n","    first_names = [\"Alice\", \"Bob\", \"Carol\", \"David\", \"Emma\", \"Frank\", \"Grace\",\n","                   \"Henry\", \"Isabel\", \"James\", \"Karen\", \"Leo\", \"Maria\", \"Nathan\"]\n","    last_names  = [\"Smith\", \"Johnson\", \"Williams\", \"Brown\", \"Jones\", \"Garcia\",\n","                   \"Miller\", \"Davis\", \"Wilson\", \"Taylor\", \"Anderson\", \"Thomas\"]\n","    regions     = [\"North\", \"South\", \"East\", \"West\", \"Central\"]\n","    base_date   = datetime(2020, 1, 1)\n","    order_base  = datetime(2023, 1, 1)\n","\n","    df = pd.DataFrame({\n","        \"customer_id\": range(1000, 1000 + n_rows),\n","        \"name\":  [f\"{random.choice(first_names)} {random.choice(last_names)}\" for _ in range(n_rows)],\n","        \"email\": [f\"user{i}@example.com\" for i in range(n_rows)],\n","        \"phone\": [f\"{random.randint(200,999)}-{random.randint(200,999)}-{random.randint(1000,9999)}\"\n","                  for _ in range(n_rows)],\n","        \"age\":   np.random.randint(18, 75, n_rows).tolist(),\n","        \"signup_date\": [(base_date + timedelta(days=random.randint(0, 1460))).strftime(\"%Y-%m-%d\")\n","                        for _ in range(n_rows)],\n","        \"order_date\":  [(order_base + timedelta(days=random.randint(0, 729))).strftime(\"%Y-%m-%d\")\n","                        for _ in range(n_rows)],\n","        \"order_value\": np.round(np.random.normal(150, 80, n_rows), 2).tolist(),\n","        \"product_id\":  [random.randint(1, 50) for _ in range(n_rows)],\n","        \"region\":      [random.choice(regions) for _ in range(n_rows)],\n","    })\n","\n","    # Inject missing values\n","    for col, frac in [(\"phone\", 0.15), (\"age\", 0.12), (\"email\", 0.08)]:\n","        idx = np.random.choice(df.index, size=int(n_rows * frac), replace=False)\n","        df.loc[idx, col] = np.nan\n","\n","    # Inject age outliers\n","    for age, idx in zip([0, 150, 999, -5, 200], np.random.choice(df.index, 5, replace=False)):\n","        df.at[idx, \"age\"] = age\n","\n","    # Inject negative order values\n","    neg_idx = np.random.choice(df.index, 25, replace=False)\n","    df.loc[neg_idx, \"order_value\"] = -abs(df.loc[neg_idx, \"order_value\"])\n","\n","    # Inject malformed emails\n","    bad_emails = [\"notanemail\", \"missing_at.com\", \"double@@ex.com\", \"no-domain@\", \"spaces in@e.com\", \"@no-local.com\"]\n","    for bad, idx in zip(bad_emails, np.random.choice(df.index, len(bad_emails), replace=False)):\n","        df.at[idx, \"email\"] = bad\n","\n","    # Inject mixed date formats\n","    for i in np.random.choice(df.index, 50, replace=False):\n","        d = df.at[i, \"signup_date\"]\n","        if isinstance(d, str) and len(d) == 10:\n","            p = d.split(\"-\")\n","            df.at[i, \"signup_date\"] = f\"{p[2]}/{p[1]}/{p[0]}\"\n","\n","    # Inject referential integrity violations\n","    for idx in np.random.choice(df.index, 30, replace=False):\n","        df.at[idx, \"product_id\"] = random.choice([99, 100, 150, 999, 1000])\n","\n","    # Inject exact duplicates\n","    df = pd.concat([df, df.sample(5, random_state=seed)], ignore_index=True)\n","    df = df.sample(frac=1.0, random_state=seed).reset_index(drop=True)\n","\n","    df.to_csv(path, index=False)\n","    logger.info(\"Dirty dataset saved. Shape: %s\", df.shape)\n","    return df\n","\n","\n","_df = generate_dirty_dataset(DATASET_PATH)\n","print(f\"Dataset shape: {_df.shape}\")\n","_df.head()"]},{"cell_type":"markdown","id":"1a9c70c5","metadata":{"papermill":{"duration":0.004194,"end_time":"2026-03-01T22:27:03.266929","exception":false,"start_time":"2026-03-01T22:27:03.262735","status":"completed"},"tags":[]},"source":["## Cell 6: Tool Implementations"]},{"cell_type":"code","execution_count":6,"id":"8f31f8b6","metadata":{"execution":{"iopub.execute_input":"2026-03-01T22:27:03.27769Z","iopub.status.busy":"2026-03-01T22:27:03.277313Z","iopub.status.idle":"2026-03-01T22:27:03.314332Z","shell.execute_reply":"2026-03-01T22:27:03.3132Z"},"papermill":{"duration":0.044971,"end_time":"2026-03-01T22:27:03.316146","exception":false,"start_time":"2026-03-01T22:27:03.271175","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["All tool implementations defined.\n"]}],"source":["def profile_dataset() -> dict[str, Any]:\n","    assert _df is not None\n","    numeric_cols     = _df.select_dtypes(include=[np.number]).columns.tolist()\n","    categorical_cols = _df.select_dtypes(include=[\"object\"]).columns.tolist()\n","    try:\n","        describe = _df.describe(include=\"all\").round(4).to_dict()\n","    except Exception:\n","        describe = {}\n","    return {\n","        \"shape\":              {\"rows\": len(_df), \"columns\": len(_df.columns)},\n","        \"column_types\":       _df.dtypes.astype(str).to_dict(),\n","        \"null_counts\":        _df.isnull().sum().to_dict(),\n","        \"memory_kb\":          round(_df.memory_usage(deep=True).sum() / 1024, 2),\n","        \"numeric_columns\":    numeric_cols,\n","        \"categorical_columns\": categorical_cols,\n","        \"descriptive_stats\":  describe,\n","    }\n","\n","\n","def check_missing_values(columns: Optional[list[str]] = None) -> dict[str, Any]:\n","    assert _df is not None\n","    cols = columns or _df.columns.tolist()\n","    n = len(_df)\n","    results = []\n","    for col in cols:\n","        if col not in _df.columns:\n","            continue\n","        null_count = int(_df[col].isnull().sum())\n","        pct = null_count / n if n else 0.0\n","        severity = (\n","            \"CRITICAL\" if pct > MISSING_CRITICAL_THRESHOLD else\n","            \"WARNING\"  if pct > MISSING_WARNING_THRESHOLD  else \"OK\"\n","        )\n","        results.append({\"column\": col, \"null_count\": null_count,\n","                         \"null_percentage\": round(pct * 100, 2), \"severity\": severity})\n","    results.sort(key=lambda x: x[\"null_percentage\"], reverse=True)\n","\n","    # Visualise\n","    cols_with_missing = [r for r in results if r[\"null_count\"] > 0]\n","    if cols_with_missing:\n","        fig, ax = plt.subplots(figsize=(10, 4))\n","        colors = [\"#e74c3c\" if r[\"severity\"] == \"CRITICAL\" else\n","                  \"#f39c12\" if r[\"severity\"] == \"WARNING\" else \"#2ecc71\"\n","                  for r in cols_with_missing]\n","        ax.barh([r[\"column\"] for r in cols_with_missing],\n","                [r[\"null_percentage\"] for r in cols_with_missing], color=colors)\n","        ax.axvline(MISSING_CRITICAL_THRESHOLD * 100, color=\"red\",    linestyle=\"--\", alpha=0.6, label=\"Critical (20%)\")\n","        ax.axvline(MISSING_WARNING_THRESHOLD  * 100, color=\"orange\", linestyle=\"--\", alpha=0.6, label=\"Warning (5%)\")\n","        ax.set_xlabel(\"Missing %\")\n","        ax.set_title(\"Missing Value Rate by Column\", fontweight=\"bold\")\n","        ax.legend()\n","        plt.tight_layout()\n","        plt.savefig(\"dq_missing_values.png\", dpi=150)\n","        plt.show()\n","        plt.close()\n","\n","    critical = [r[\"column\"] for r in results if r[\"severity\"] == \"CRITICAL\"]\n","    warnings = [r[\"column\"] for r in results if r[\"severity\"] == \"WARNING\"]\n","    return {\"results\": results, \"summary\": {\"critical_columns\": critical, \"warning_columns\": warnings,\n","                                             \"total_missing_cells\": sum(r[\"null_count\"] for r in results)}}\n","\n","\n","def check_duplicates(key_columns: Optional[list[str]] = None) -> dict[str, Any]:\n","    assert _df is not None\n","    exact_mask  = _df.duplicated(keep=\"first\")\n","    exact_count = int(exact_mask.sum())\n","    result: dict[str, Any] = {\n","        \"exact_duplicates\": {\n","            \"count\": exact_count,\n","            \"percentage\": round(exact_count / len(_df) * 100, 2),\n","            \"examples\": _df[exact_mask].head(5).to_dict(orient=\"records\"),\n","        }\n","    }\n","    if key_columns:\n","        valid_keys = [c for c in key_columns if c in _df.columns]\n","        if valid_keys:\n","            key_mask = _df.duplicated(subset=valid_keys, keep=\"first\")\n","            result[\"key_column_duplicates\"] = {\n","                \"key_columns\": valid_keys,\n","                \"count\": int(key_mask.sum()),\n","                \"percentage\": round(key_mask.sum() / len(_df) * 100, 2),\n","            }\n","    return result\n","\n","\n","def check_outliers(columns: Optional[list[str]] = None) -> dict[str, Any]:\n","    assert _df is not None\n","    if columns:\n","        numeric_cols = [c for c in columns if c in _df.columns and pd.api.types.is_numeric_dtype(_df[c])]\n","    else:\n","        numeric_cols = _df.select_dtypes(include=[np.number]).columns.tolist()\n","    results = []\n","    for col in numeric_cols:\n","        series = _df[col].dropna()\n","        if len(series) < 10:\n","            continue\n","        z_scores = np.abs(stats.zscore(series))\n","        z_mask   = z_scores > ZSCORE_OUTLIER_THRESHOLD\n","        q1, q3   = series.quantile(0.25), series.quantile(0.75)\n","        iqr      = q3 - q1\n","        lower, upper = q1 - IQR_FENCE_MULTIPLIER * iqr, q3 + IQR_FENCE_MULTIPLIER * iqr\n","        iqr_mask = (series < lower) | (series > upper)\n","        combined = z_mask | iqr_mask\n","        if combined.sum() > 0:\n","            results.append({\n","                \"column\": col,\n","                \"zscore_count\":   int(z_mask.sum()),\n","                \"iqr_count\":      int(iqr_mask.sum()),\n","                \"combined_count\": int(combined.sum()),\n","                \"outlier_sample\": sorted(series[combined].unique().tolist())[:10],\n","                \"lower_fence\":    round(float(lower), 4),\n","                \"upper_fence\":    round(float(upper), 4),\n","                \"min\":            round(float(series.min()), 4),\n","                \"max\":            round(float(series.max()), 4),\n","            })\n","\n","    # Visualise\n","    if results:\n","        cols_to_plot = [r[\"column\"] for r in results]\n","        fig, axes = plt.subplots(1, len(cols_to_plot), figsize=(5 * len(cols_to_plot), 5))\n","        if len(cols_to_plot) == 1:\n","            axes = [axes]\n","        for ax, col in zip(axes, cols_to_plot):\n","            _df[col].dropna().plot.box(ax=ax)\n","            ax.set_title(col, fontweight=\"bold\")\n","            ax.set_ylabel(\"Value\")\n","        plt.suptitle(\"Outlier Detection — Box Plots\", fontsize=14, fontweight=\"bold\", y=1.02)\n","        plt.tight_layout()\n","        plt.savefig(\"dq_outliers.png\", dpi=150, bbox_inches=\"tight\")\n","        plt.show()\n","        plt.close()\n","\n","    return {\"outlier_results\": results, \"columns_checked\": len(numeric_cols)}\n","\n","\n","def check_format_violations(checks: list[dict[str, str]]) -> dict[str, Any]:\n","    assert _df is not None\n","    results = []\n","    for check in checks:\n","        col, pattern_name = check.get(\"column\", \"\"), check.get(\"pattern_name\", \"\")\n","        if col not in _df.columns:\n","            results.append({\"column\": col, \"error\": \"Column not found.\"}); continue\n","        if pattern_name not in _FORMAT_PATTERNS:\n","            results.append({\"column\": col, \"error\": f\"Unknown pattern '{pattern_name}'.\"}); continue\n","        pattern  = _FORMAT_PATTERNS[pattern_name]\n","        non_null = _df[col].dropna().astype(str)\n","        violations = non_null[~non_null.apply(lambda x: bool(pattern.match(x)))]\n","        results.append({\n","            \"column\": col, \"pattern\": pattern_name,\n","            \"violation_count\": len(violations),\n","            \"violation_percentage\": round(len(violations) / len(non_null) * 100, 2) if len(non_null) else 0,\n","            \"violation_examples\": violations.unique().tolist()[:10],\n","        })\n","    return {\"format_results\": results, \"total_violations\": sum(r.get(\"violation_count\", 0) for r in results)}\n","\n","\n","def check_referential_integrity(column: str, valid_range_min: float, valid_range_max: float) -> dict[str, Any]:\n","    assert _df is not None\n","    if column not in _df.columns:\n","        return {\"error\": f\"Column '{column}' not found.\"}\n","    series  = _df[column].dropna()\n","    invalid = series[(series < valid_range_min) | (series > valid_range_max)]\n","    return {\n","        \"column\": column,\n","        \"valid_range\": {\"min\": valid_range_min, \"max\": valid_range_max},\n","        \"orphaned_count\": len(invalid),\n","        \"orphaned_percentage\": round(len(invalid) / len(series) * 100, 2) if len(series) else 0,\n","        \"invalid_values_sample\": sorted(invalid.unique().tolist())[:10],\n","    }\n","\n","\n","def generate_dq_report(\n","    dataset_name: str, total_rows: int, total_columns: int,\n","    issues_found: list[dict[str, Any]], overall_quality_score: float,\n",") -> dict[str, Any]:\n","    severity_order = {\"CRITICAL\": 0, \"WARNING\": 1, \"INFO\": 2}\n","    issues = sorted(issues_found, key=lambda x: severity_order.get(x.get(\"severity\", \"INFO\"), 2))\n","    critical_n = sum(1 for i in issues if i.get(\"severity\") == \"CRITICAL\")\n","    warning_n  = sum(1 for i in issues if i.get(\"severity\") == \"WARNING\")\n","\n","    table = \"| # | Severity | Column | Category | Affected Rows | Description |\\n\"\n","    table += \"|---|----------|--------|----------|---------------|-------------|\\n\"\n","    for n, issue in enumerate(issues, 1):\n","        table += (f\"| {n} | {issue.get('severity','INFO')} | {issue.get('column','N/A')} \"\n","                  f\"| {issue.get('category','N/A')} | {issue.get('affected_rows',0):,} \"\n","                  f\"| {issue.get('description','')} |\\n\")\n","\n","    remediation = \"\"\n","    for n, issue in enumerate(issues, 1):\n","        remediation += (f\"### Fix {n}: {issue.get('column','N/A')} — {issue.get('category','')}\\n\"\n","                        f\"**Severity:** {issue.get('severity','INFO')}  \\n\"\n","                        f\"**Recommended Action:** {issue.get('recommended_fix','No fix specified.')}\\n\\n\")\n","\n","    score_bar = \"|\" * int(overall_quality_score // 2) + \"-\" * (50 - int(overall_quality_score // 2))\n","    report = f\"\"\"# Data Quality Audit Report\n","\n","**Dataset:** {dataset_name}\n","**Audit Date:** {datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")}\n","**Dataset Size:** {total_rows:,} rows x {total_columns} columns\n","\n","---\n","\n","## Overall Data Quality Score\n","\n","```\n","Score: {overall_quality_score:.1f} / 100\n","{score_bar} {overall_quality_score:.0f}%\n","```\n","\n","**Critical Issues:** {critical_n}  \n","**Warnings:** {warning_n}  \n","**Total Issues:** {len(issues)}\n","\n","---\n","\n","## Issue Inventory\n","\n","{table}\n","\n","---\n","\n","## Remediation Plan\n","\n","{remediation}\n","\n","---\n","\n","*Generated by the Autonomous Data Quality Agent.*\n","\"\"\"\n","    path = f\"dq_report_{dataset_name.replace(' ', '_').lower()}.md\"\n","    with open(path, \"w\", encoding=\"utf-8\") as fh:\n","        fh.write(report)\n","    logger.info(\"Report saved to '%s'. Score: %.1f/100\", path, overall_quality_score)\n","    return {\"report_path\": path, \"score\": overall_quality_score, \"status\": \"success\"}\n","\n","\n","print(\"All tool implementations defined.\")"]},{"cell_type":"markdown","id":"3910592c","metadata":{"papermill":{"duration":0.004326,"end_time":"2026-03-01T22:27:03.32496","exception":false,"start_time":"2026-03-01T22:27:03.320634","status":"completed"},"tags":[]},"source":["## Cell 7: Tool Dispatcher"]},{"cell_type":"code","execution_count":7,"id":"bb8ae420","metadata":{"execution":{"iopub.execute_input":"2026-03-01T22:27:03.335469Z","iopub.status.busy":"2026-03-01T22:27:03.335117Z","iopub.status.idle":"2026-03-01T22:27:03.342268Z","shell.execute_reply":"2026-03-01T22:27:03.34121Z"},"papermill":{"duration":0.014666,"end_time":"2026-03-01T22:27:03.344009","exception":false,"start_time":"2026-03-01T22:27:03.329343","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["dispatch_tool() defined.\n"]}],"source":["_DISPATCH_TABLE: dict[str, Any] = {\n","    \"profile_dataset\":           profile_dataset,\n","    \"check_missing_values\":      check_missing_values,\n","    \"check_duplicates\":          check_duplicates,\n","    \"check_outliers\":            check_outliers,\n","    \"check_format_violations\":   check_format_violations,\n","    \"check_referential_integrity\": check_referential_integrity,\n","    \"generate_dq_report\":        generate_dq_report,\n","}\n","\n","\n","def dispatch_tool(tool_name: str, tool_input: dict[str, Any]) -> Any:\n","    \"\"\"Route a Claude tool-use request to its implementation.\"\"\"\n","    if tool_name not in _DISPATCH_TABLE:\n","        return {\"error\": f\"Unknown tool: '{tool_name}'.\"}\n","    try:\n","        return _DISPATCH_TABLE[tool_name](**tool_input)\n","    except TypeError as exc:\n","        logger.error(\"Bad arguments for '%s': %s\", tool_name, exc)\n","        return {\"error\": f\"Invalid arguments: {exc}\"}\n","\n","\n","print(\"dispatch_tool() defined.\")"]},{"cell_type":"markdown","id":"7d413719","metadata":{"papermill":{"duration":0.00431,"end_time":"2026-03-01T22:27:03.352829","exception":false,"start_time":"2026-03-01T22:27:03.348519","status":"completed"},"tags":[]},"source":["## Cell 8: The Agent"]},{"cell_type":"code","execution_count":8,"id":"78ed1d15","metadata":{"execution":{"iopub.execute_input":"2026-03-01T22:27:03.363115Z","iopub.status.busy":"2026-03-01T22:27:03.362771Z","iopub.status.idle":"2026-03-01T22:27:03.373237Z","shell.execute_reply":"2026-03-01T22:27:03.372113Z"},"papermill":{"duration":0.017904,"end_time":"2026-03-01T22:27:03.374978","exception":false,"start_time":"2026-03-01T22:27:03.357074","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["run_dq_agent() defined.\n"]}],"source":["_SYSTEM_PROMPT = \"\"\"You are a senior data engineer specialising in data quality assurance.\n","\n","Autonomously audit the loaded dataset for all categories of data quality issues.\n","\n","Follow this workflow:\n","1. profile_dataset()              — understand structure and types\n","2. check_missing_values()         — null analysis across all columns\n","3. check_duplicates()             — detect duplicate records by key column\n","4. check_outliers()               — statistical anomaly detection on numeric columns\n","5. check_format_violations()      — regex validation for email, phone, dates\n","6. check_referential_integrity()  — foreign key range validation for ID columns\n","7. generate_dq_report()           — compile all findings into a scored report\n","\n","Severity rules:\n","- CRITICAL: will break pipelines or corrupt downstream analysis\n","- WARNING: degrades quality but may not immediately fail\n","- INFO: minor issue, low business impact\n","\n","Be thorough. Cover all check categories. Provide specific, actionable remediation code.\"\"\"\n","\n","\n","def run_dq_agent(dataset_name: str = \"customer_orders\") -> str:\n","    assert _df is not None, \"Dataset not loaded.\"\n","    client = anthropic.Anthropic()\n","    logger.info(\"Starting DQ agent for: '%s'\", dataset_name)\n","\n","    messages: list[dict[str, Any]] = [{\n","        \"role\": \