descriptive statistics. \"\n","            \"Always call this first.\"\n","        ),\n","        \"input_schema\": {\"type\": \"object\", \"properties\": {}},\n","    },\n","    {\n","        \"name\": \"check_missing_values\",\n","        \"description\": (\n","            \"Detect missing values across all columns. Returns null count, percentage, \"\n","            \"and severity (CRITICAL >20%, WARNING >5%, OK otherwise) per column.\"\n","        ),\n","        \"input_schema\": {\n","            \"type\": \"object\",\n","            \"properties\": {\n","                \"columns\": {\n","                    \"type\": \"array\",\n","                    \"items\": {\"type\": \"string\"},\n","                    \"description\": \"Columns to check. Omit to check all.\",\n","                }\n","            },\n","        },\n","    },\n","    {\n","        \"name\": \"check_duplicates\",\n","        \"description\": \"Identify exact duplicate rows and near-duplicates on specified key columns.\",\n","        \"input_schema\": {\n","            \"type\": \"object\",\n","            \"properties\": {\n","                \"key_columns\": {\n","                    \"type\": \"array\",\n","                    \"items\": {\"type\": \"string\"},\n","                    \"description\": \"Columns that should uniquely identify a record.\",\n","                }\n","            },\n","        },\n","    },\n","    {\n","        \"name\": \"check_outliers\",\n","        \"description\": \"Detect outliers in numeric columns using Z-score and IQR (Tukey fence) methods.\",\n","        \"input_schema\": {\n","            \"type\": \"object\",\n","            \"properties\": {\n","                \"columns\": {\n","                    \"type\": \"array\",\n","                    \"items\": {\"type\": \"string\"},\n","                    \"description\": \"Numeric columns to check. Omit for all numeric columns.\",\n","                }\n","            },\n","        },\n","    },\n","    {\n","        \"name\": \"check_format_violations\",\n","        \"description\": (\n","            \"Validate text columns against regex patterns. \"\n","            \"Built-in patterns: email, phone_us, date_iso, date_uk, positive_number.\"\n","        ),\n","        \"input_schema\": {\n","            \"type\": \"object\",\n","            \"properties\": {\n","                \"checks\": {\n","                    \"type\": \"array\",\n","                    \"items\": {\n","                        \"type\": \"object\",\n","                        \"properties\": {\n","                            \"column\": {\"type\": \"string\"},\n","                            \"pattern_name\": {\n","                                \"type\": \"string\",\n","                                \"enum\": [\"email\", \"phone_us\", \"date_iso\", \"date_uk\", \"positive_number\"],\n","                            },\n","                        },\n","                        \"required\": [\"column\", \"pattern_name\"],\n","                    },\n","                }\n","            },\n","            \"required\": [\"checks\"],\n","        },\n","    },\n","    {\n","        \"name\": \"check_referential_integrity\",\n","        \"description\": (\n","            \"Verify foreign key values fall within a valid numeric range. \"\n","            \"Returns orphaned (invalid) value count and examples.\"\n","        ),\n","        \"input_schema\": {\n","            \"type\": \"object\",\n","            \"properties\": {\n","                \"column\": {\"type\": \"string\"},\n","                \"valid_range_min\": {\"type\": \"number\"},\n","                \"valid_range_max\": {\"type\": \"number\"},\n","            },\n","            \"required\": [\"column\", \"valid_range_min\", \"valid_range_max\"],\n","        },\n","    },\n","    {\n","        \"name\": \"generate_dq_report\",\n","        \"description\": (\n","            \"Compile all findings into a scored, prioritised 